---
import CategoryList from '@/components/CategoryList.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import { getCategoryPath } from '@/i18n/path'
import { ui } from '@/i18n/ui'
import Layout from '@/layouts/Layout.astro'
import {
  getCategoriesWithCounts,
  getUserCategoriesWithCounts,
} from '@/utils/content'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const currentLang = getLangFromLocale(Astro.currentLocale)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

// System: tech / life / science. URL is the lowercase type value;
// display name comes from i18n (capitalized / localized). Filter out
// zero-count rows — they'd link to a detail page that exists in
// `getStaticPaths` only when count > 0.
const systemCats = (await getCategoriesWithCounts(currentLang))
  .filter(c => c.count > 0)
  .map(c => ({
    name: (currentUI[c.name as keyof typeof currentUI] as string) || c.name,
    count: c.count,
    href: getCategoryPath(c.name, currentLang),
  }))

// User: as-authored in frontmatter; case preserved in URL via encoding.
const userCats = (await getUserCategoriesWithCounts(currentLang))
  .map(c => ({
    name: c.name,
    count: c.count,
    href: getCategoryPath(c.name, currentLang),
  }))

const totalCount = systemCats.length + userCats.length
const hasBoth = systemCats.length > 0 && userCats.length > 0
---

<Layout postTitle={currentUI.categories || 'Categories'}>
  <section class="mb-7.5">
    <h1 class="mb-2 text-5 font-bold cjk:tracking-wide lg:text-6">
      {currentUI.categories || 'Categories'}
    </h1>
    <p class="mb-6 text-3.5 c-secondary">
      {totalCount} {currentUI.categoriesInTotal || 'categories in total'}
    </p>
    <div class="uno-decorative-line" />

    {/*
      Two-source merge with no labels. System categories appear above
      user ones; the alert reader perceives the rhythm break in the
      whitespace, the casual reader just reads one continuous index.
      Whitespace is the only group signal — DESIGN.md "strip on doubt".
    */}
    {systemCats.length > 0 && (
      <CategoryList items={systemCats} />
    )}

    {userCats.length > 0 && (
      <div class:list={[hasBoth && 'mt-7.5 lg:mt-10.5']}>
        <CategoryList items={userCats} />
      </div>
    )}
  </section>
</Layout>
