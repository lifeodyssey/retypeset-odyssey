---
import type { Language } from '@/i18n/config'
import { getTagPath } from '@/i18n/path'

interface TagWithCount {
  name: string
  count: number
}

interface Props {
  tags: string[] | TagWithCount[]
  currentTag?: string
  lang: Language
  cloudStyle?: boolean
}

const { tags, currentTag = '', lang, cloudStyle = false } = Astro.props

// Normalize input to TagWithCount
const normalizedTags: TagWithCount[] = tags.map(tag =>
  typeof tag === 'string' ? { name: tag, count: 1 } : tag,
)

// Cloud-only: drop singletons (count == 1). Tags that appear in just one
// post don't carry "theme" weight — they're per-post keywords. Including
// them buries the actual themes under 50+ tiny entries (long-tail noise).
// Trim them, the singletons remain reachable via search / individual posts.
// The pill-list (non-cloud) branch keeps everything since it's used in
// places that need the full set.
const visibleTags = cloudStyle
  ? normalizedTags.filter(t => t.count >= 2)
  : normalizedTags

const counts = visibleTags.map(t => t.count)
const maxCount = counts.length > 0 ? Math.max(...counts) : 1
const minCount = counts.length > 0 ? Math.min(...counts) : 1
const countRange = maxCount - minCount || 1

// Six-tier weight bucket via percentile of count range.
// Tier 1 = heaviest, tier 6 = long tail.
function tierOf(count: number): 1 | 2 | 3 | 4 | 5 | 6 {
  const ratio = (count - minCount) / countRange
  if (ratio >= 0.85) return 1
  if (ratio >= 0.55) return 2
  if (ratio >= 0.32) return 3
  if (ratio >= 0.16) return 4
  if (ratio >= 0.05) return 5
  return 6
}

// Pyramid reorder for the centered cloud: take the count-desc list,
// alternately prepend / append items. The biggest item lands at the
// visual middle of the array; smaller items fan out to both ends.
// With `flex-wrap + justify-center` the heaviest tag ends up in the
// middle row of the rendered cloud — the Wordle "centre = heavy"
// affordance without needing canvas / spiral packing.
const cloudTags: TagWithCount[] = (() => {
  if (!cloudStyle) return normalizedTags
  const sortedDesc = [...visibleTags].sort((a, b) => b.count - a.count)
  const pyramid: TagWithCount[] = []
  for (let i = 0; i < sortedDesc.length; i++) {
    if (i % 2 === 0) pyramid.unshift(sortedDesc[i])
    else pyramid.push(sortedDesc[i])
  }
  return pyramid
})()

// Tier → tailwind/uno class fragments. All inline so UnoCSS picks them
// up from the template scan (Astro scoped `<style>` blocks bypass the
// transformer in dev — same lesson we learned in CategoryList). One-axis
// tier mapping keeps everything in one place.
const TIER_CLASS: Record<1 | 2 | 3 | 4 | 5 | 6, string> = {
  1: 'text-[2.5rem] font-semibold c-primary',
  2: 'text-[1.85rem] font-medium c-primary',
  3: 'text-[1.45rem] c-primary',
  4: 'text-[1.15rem] c-[oklch(35%_0.005_298)] dark:c-[oklch(80%_0.005_298)]',
  5: 'text-3.9 c-secondary',
  6: 'text-3.4 c-secondary op-70',
}
---

{cloudStyle ? (
  <ul class="list-none p-0 m-0 flex flex-wrap items-baseline justify-center gap-x-4 gap-y-1 py-2 no-heti">
    {cloudTags.map(tag => (
      <li>
        <a
          href={getTagPath(tag.name, lang)}
          class:list={[
            'relative z-0 inline-block px-0 py-0.5 tracking-wide-0.05',
            'highlight-hover after:bottom-0.12em transition-colors',
            TIER_CLASS[tierOf(tag.count)],
            currentTag === tag.name && 'font-semibold',
          ]}
        >{tag.name}</a>
      </li>
    ))}
  </ul>
) : (
  <ul class="list-none p-0 m-0 no-heti flex flex-col gap-1.5">
    {normalizedTags.map(tag => (
      <li>
        <a
          href={getTagPath(tag.name, lang)}
          class:list={[
            'relative inline-flex items-baseline justify-between gap-6',
            'py-1 transition-colors highlight-hover after:bottom-0.35em',
            currentTag === tag.name
              ? 'c-primary font-medium'
              : 'c-secondary/85 hover:c-primary',
          ]}
        >
          <span class="text-4 cjk:tracking-wide">{tag.name}</span>
          <span class="text-3.5 c-secondary/55 tabular-nums">{tag.count}</span>
        </a>
      </li>
    ))}
  </ul>
)}
